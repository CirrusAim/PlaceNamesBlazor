@page "/{locale:regex(no|en)}/Account/Register"
@model PlaceNamesBlazor.Pages.Account.RegisterModel
@inject IStringLocalizer<SharedResource> Loc
@{
    ViewData["Title"] = Loc["Account_Register"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">@Loc["Account_Register"]</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mb-3" role="alert">@Model.ErrorMessage</div>
                }
                <form method="post" asp-page-handler="Register">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First name</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last name</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <div class="form-text">At least 8 characters, including uppercase, lowercase, and a digit.</div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Telephone" class="form-label">Telephone (optional)</label>
                        <input asp-for="Telephone" class="form-control" type="tel" />
                    </div>
                    <button type="submit" class="btn btn-primary">Register</button>
                </form>
                <p class="mt-3 mb-0 text-muted small">
                    <a href="/@(Model.Locale)/Account/Login">@Loc["Account_LogIn"]</a> | <a href="/@(Model.Locale)">@Loc["Account_Home"]</a>
                </p>
            </div>
        </div>
    </div>
</div>
