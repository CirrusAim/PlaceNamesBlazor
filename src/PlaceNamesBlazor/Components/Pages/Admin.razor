    private async Task SubmitReportAction()
    {
        if (_reportAction == null || string.IsNullOrWhiteSpace(_reportInitialer)) return;
        if (_reportActionApprove)
            await ReportingService.ApproveReportAsync(_reportAction.RapporteringshistorikkId, _reportInitialer.Trim(), _reportKommentarer, _currentUserId);
        else
            await ReportingService.RejectReportAsync(_reportAction.RapporteringshistorikkId, _reportInitialer.Trim(), _currentUserId);
        var me = await AuthService.GetCurrentUserAsync();
        var targetDesc = $"{_reportAction.StempeltekstOppe} – {_reportAction.RapportoerInitialer}";
        var actionType = _reportActionApprove ? "report_approved" : "report_rejected";
        await AuditService.LogAsync(_currentUserId, me?.Email ?? "", _currentUserRole ?? "", actionType, "REPORT", _reportAction.RapporteringshistorikkId, targetDesc, null);
        CloseReportModal();
        await LoadReports();
        await LoadPendingCounts();
    }

