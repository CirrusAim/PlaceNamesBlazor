    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        _currentUserRole = user?.Role;
        _currentUserId = user?.UserId ?? 0;
        _isApprovedReporter = false;
        if (user != null)
        {
            var reporter = await ReporterService.GetByUserIdAsync(user.UserId);
            _isApprovedReporter = !string.IsNullOrEmpty(reporter?.Status) && string.Equals(reporter.Status.Trim(), "approved", StringComparison.OrdinalIgnoreCase);
        }
        if (string.IsNullOrEmpty(Tab) || Tab is not ("records" or "reports" or "users" or "subcategories" or "stamptypes" or "audit"))
            Tab = "records";
        if (Tab == "audit" && _currentUserRole != "admin")
        {
            Navigation.NavigateTo(GetPath("admin/records"), replace: true);
            return;
        }
        if (Tab == "audit" && _currentUserRole == "admin")
            await LoadAuditLogs();
        if (Tab == "users")
            await LoadUsers();
        if (Tab == "reports")
            await LoadReports();
        if (Tab == "records")
            await LoadRecordsDropdowns();
        await LoadPendingCounts();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Tab == "audit" && _currentUserRole != "admin")
        {
            Navigation.NavigateTo(GetPath("admin/records"), replace: true);
            return;
        }
        if (Tab == "audit" && _currentUserRole == "admin" && _auditLogs.Count == 0 && !_auditLoading)
            await LoadAuditLogs();
        if (Tab == "users" && _usersList.Count == 0)
            await LoadUsers();
        if (Tab == "reports" && _reportsList.Count == 0 && _reportsStatusFilter == null)
        {
            await LoadReports();
            await LoadPendingCounts();
        }
        if (Tab == "records" && _recordsDropdowns.Fylker.Count == 0)
            await LoadRecordsDropdowns();
        if (Tab == "subcategories")
        {
            if (_recordsDropdowns.Stempeltyper.Count == 0)
                await LoadRecordsDropdowns();
            await LoadSubcategoriesList();
        }
    }

    private async Task LoadRecordsDropdowns()
    {
        _recordsDropdowns = await DropdownService.GetDropdownsAsync();
    }

    private async Task LoadPendingCounts()
    {
        _pendingReportsCount = await ReportingService.GetPendingReportCountAsync();
        _pendingReportersCount = await AdminUserService.GetPendingReporterCountAsync();
    }

    private async Task LoadRecords()
    {
        _recordsLoading = true;
        _recordsResult = null;
        _recordsSelectedIds.Clear();
        try
        {
            var request = new SearchRequest
            {
                Poststed = string.IsNullOrWhiteSpace(_recordsPoststed) ? null : _recordsPoststed.Trim(),
                Stempeltekst = string.IsNullOrWhiteSpace(_recordsStempeltekst) ? null : _recordsStempeltekst.Trim(),
                FylkeId = int.TryParse(_recordsFylkeId, out var fid) ? fid : null,
                StempeltypeId = int.TryParse(_recordsStempeltypeId, out var sid) ? sid : null,
                Page = _recordsPage,
                PageSize = AdminPageSize
            };
            _recordsResult = await StampSearchService.SearchAsync(request);
        }
        finally
        {
            _recordsLoading = false;
        }
    }

    private async Task RecordsGoToPage(int page)
    {
        if (page < 1) return;
        _recordsPage = page;
        await LoadRecords();
    }

    private Task RecordsFirstPage() => RecordsGoToPage(1);
    private Task RecordsPrevPage() => RecordsGoToPage(_recordsPage - 1);
    private Task RecordsNextPage() => RecordsGoToPage(_recordsPage + 1);
    private async Task RecordsLastPage()
    {
        if (_recordsResult?.Result == null) return;
        var total = _recordsResult.Result.TotalCount;
        var totalPages = (total + AdminPageSize - 1) / AdminPageSize;
        if (totalPages < 1) totalPages = 1;
        await RecordsGoToPage(totalPages);
    }

    private async Task SearchRecords()
    {
        _recordsPage = 1;
        await LoadRecords();
    }

    private int GetRecordsTotalPages()
    {
        var total = _recordsResult?.Result?.TotalCount ?? 0;
        var t = (total + AdminPageSize - 1) / AdminPageSize;
        return t < 1 ? 1 : t;
    }

    private int GetReportsTotalPages()
    {
        var t = (_reportsTotalCount + AdminPageSize - 1) / AdminPageSize;
        return t < 1 ? 1 : t;
    }

    private static bool UserMatchesSearch(UserListDto u, string term)
    {
        if (u.FirstName != null && u.FirstName.ToLowerInvariant().Contains(term)) return true;
        if (u.MiddleName != null && u.MiddleName.ToLowerInvariant().Contains(term)) return true;
        if (u.LastName != null && u.LastName.ToLowerInvariant().Contains(term)) return true;
        if (u.Email != null && u.Email.ToLowerInvariant().Contains(term)) return true;
        if (u.Username != null && u.Username.ToLowerInvariant().Contains(term)) return true;
        var fullName = string.Join(" ", new[] { u.FirstName ?? "", u.MiddleName ?? "", u.LastName ?? "" }.Where(s => !string.IsNullOrWhiteSpace(s))).Trim().ToLowerInvariant();
        return fullName.Contains(term);
    }

    private IEnumerable<UserListDto> GetUsersFiltered()
    {
        var q = _usersList.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_usersRoleFilter))
        {
            var role = _usersRoleFilter.Trim();
            q = q.Where(u => string.Equals(u.Role, role, StringComparison.OrdinalIgnoreCase));
        }
        if (!string.IsNullOrWhiteSpace(_usersSearchFilter))
        {
            var term = _usersSearchFilter.Trim().ToLowerInvariant();
            q = q.Where(u => UserMatchesSearch(u, term));
        }
        if (!string.IsNullOrWhiteSpace(_usersReporterFilter))
        {
            var rep = _usersReporterFilter.Trim().ToLowerInvariant();
            q = rep switch
            {
                "none" => q.Where(u => string.IsNullOrEmpty(u.ReporterStatus)),
                "pending" => q.Where(u => string.Equals(u.ReporterStatus, "pending", StringComparison.OrdinalIgnoreCase)),
                "approved" => q.Where(u => string.Equals(u.ReporterStatus, "approved", StringComparison.OrdinalIgnoreCase)),
                "rejected" => q.Where(u => string.Equals(u.ReporterStatus, "rejected", StringComparison.OrdinalIgnoreCase)),
                _ => q
            };
        }
        return q;
    }

    private int GetUsersTotalPages()
    {
        var count = GetUsersFiltered().Count();
        var t = (count + AdminPageSize - 1) / AdminPageSize;
        return t < 1 ? 1 : t;
    }

    private int GetUsersCurrentPage()
    {
        return Math.Min(_usersPage, GetUsersTotalPages());
    }

    private List<UserListDto> GetUsersPaged()
    {
        var filtered = GetUsersFiltered().ToList();
        int totalPages = (filtered.Count + AdminPageSize - 1) / AdminPageSize;
        if (totalPages < 1) totalPages = 1;
        int page = Math.Min(_usersPage, totalPages);
        return filtered.Skip((page - 1) * AdminPageSize).Take(AdminPageSize).ToList();
    }

    private void ApplyUsersFilters()
    {
        _usersPage = 1;
        StateHasChanged();
    }

    private void ClearUsersFilters()
    {
        _usersRoleFilter = "";
        _usersSearchFilter = "";
        _usersReporterFilter = "";
        _usersPage = 1;
        StateHasChanged();
    }

    private int GetAuditTotalPages()
    {
