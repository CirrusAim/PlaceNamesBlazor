    private string FormatAuditDetails(string detailsJson, string actionType, IStringLocalizer<SharedResource> loc)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(detailsJson);
            var sb = new System.Text.StringBuilder();
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                var label = prop.Name switch
                {
                    "email" => loc["Admin_Email"].Value,
                    "old_role" => loc["Audit_OldRole"].Value,
                    "new_role" => loc["Audit_NewRole"].Value,
                    "field_changes" => loc["Audit_FieldChanges"].Value,
                    "role" => loc["Admin_Role"].Value,
                    _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(prop.Name.Replace("_", " "))
                };
                sb.AppendLine($"{label}: {prop.Value}");
            }
            return sb.Length > 0 ? sb.ToString().TrimEnd() : detailsJson;
        }
        catch { return detailsJson; }
    }
