    private async Task CreateStampType()
    {
        if (string.IsNullOrWhiteSpace(_newStampTypeCode) || string.IsNullOrWhiteSpace(_newStampTypeFullTekst)) return;
        _stampTypeSaving = true;
        _stampTypeMessage = null;
        _stampTypeError = false;
        try
        {
            var (ok, _, err) = await StampTypeService.CreateAsync(_newStampTypeCode.Trim(), _newStampTypeFullTekst.Trim());
            if (ok)
            {
                _stampTypeMessage = "Stamp type created.";
                _newStampTypeCode = "";
                _newStampTypeFullTekst = "";
                _recordsDropdowns = await DropdownService.GetDropdownsAsync();
            }
            else { _stampTypeMessage = err; _stampTypeError = true; }
        }
        finally { _stampTypeSaving = false; }
    }

    private async Task LoadReports()
    {
        if (_currentUserRole != "admin" && _currentUserRole != "superuser") { _reportsList = new List<ReportDto>(); _reportsTotalCount = 0; return; }
        _reportsTotalCount = await ReportingService.GetReportsCountAsync(null, null, _reportsStatusFilter);
        var offset = (_reportsPage - 1) * AdminPageSize;
        _reportsList = (await ReportingService.GetReportsAsync(null, null, _reportsStatusFilter, AdminPageSize, offset)).ToList();
    }

    private async Task ReportsGoToPage(int page)
