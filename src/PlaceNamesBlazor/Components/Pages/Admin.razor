    private async Task OpenSubmitReportRecord(SearchResultDto r)
    {
        _submitStempelId = r.StempelId;
        _submitReportStempeltekst = r.StempeltekstOppe;
        _submitUsagePeriodOptions = (await ReportingService.GetUsagePeriodsForStampAsync(r.StempelId)).ToList();
        _submitBruksperiodeId = _submitUsagePeriodOptions.FirstOrDefault()?.BruksperiodeId ?? 0;
        _submitRapporteringsdato = DateOnly.FromDateTime(DateTime.Today);
        _submitFoersteSiste = "F";
        _submitDatoAvtrykk = "";
        _submitImagePaths = new List<string>();
        _submitReportError = null;
        _showSubmitReportModal = true;
    }

    private async Task OnAdminReportImagesChanged(InputFileChangeEventArgs e)
    {
        _submitImagePaths = new List<string>();
        foreach (var file in e.GetMultipleFiles(10))
        {
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var path = await ImageStorage.UploadAsync(stream, file.Name, "report");
                _submitImagePaths.Add(path);
            }
            catch { }
        }
    }

    private async Task SubmitReportRecord()
    {
        _submitReportError = null;
        if (_submitBruksperiodeId <= 0) { _submitReportError = "Select a usage period."; return; }
        if (string.IsNullOrWhiteSpace(_submitDatoAvtrykk)) { _submitReportError = "Date of imprint is required."; return; }
        if (_submitImagePaths.Count == 0) { _submitReportError = "At least one image is required."; return; }
        var user = await AuthService.GetCurrentUserAsync();
        if (user == null) { _submitReportError = "Not logged in."; return; }
        var reporter = await ReporterService.GetByUserIdAsync(user.UserId);
        if (reporter == null || !string.Equals(reporter.Status?.Trim(), "approved", StringComparison.OrdinalIgnoreCase)) { _submitReportError = "You must be an approved reporter."; return; }
        _submitReportLoading = true;
        try
        {
            var req = new ReportSubmitRequest
            {
                StempelId = _submitStempelId,
                BruksperiodeId = _submitBruksperiodeId,
                Rapporteringsdato = _submitRapporteringsdato,
                RapporteringFoersteSisteDato = _submitFoersteSiste,
                DatoForRapportertAvtrykk = _submitDatoAvtrykk.Trim(),
                ImagePaths = _submitImagePaths
            };
            var id = await ReportingService.SubmitReportAsync(reporter.RapportoerId, req);
            if (id.HasValue)
            {
                CloseSubmitReportModal();
                CloseRecordDetailModal();
            }
            else
                _submitReportError = "Submit failed.";
        }
        finally { _submitReportLoading = false; }
    }

    private void CloseSubmitReportModal()
    {
        _showSubmitReportModal = false;
    }

    private void ToggleRecordSelection(int stempelId)
    {
        if (_recordsSelectedIds.Contains(stempelId))
            _recordsSelectedIds.Remove(stempelId);
        else
            _recordsSelectedIds.Add(stempelId);
    }

    private void ToggleSelectAllRecords(ChangeEventArgs e)
    {
        if (_recordsResult?.Result?.Items == null) return;
        var on = e.Value as bool? ?? false;
        if (on)
            foreach (var r in _recordsResult.Result.Items)
                _recordsSelectedIds.Add(r.StempelId);
        else
            _recordsSelectedIds.Clear();
    }

    private void ConfirmDeleteRecord(int stempelId)
    {
        _recordToDeleteStempelId = stempelId;
        _showRecordDeleteConfirm = true;
    }

    private void CancelDeleteRecord()
    {
        _showRecordDeleteConfirm = false;
        _recordToDeleteStempelId = null;
    }

    private async Task DoDeleteRecord()
    {
        if (!_recordToDeleteStempelId.HasValue) return;
        var id = _recordToDeleteStempelId.Value;
        CancelDeleteRecord();
        await DeleteRecord(id);
    }

    private async Task DeleteRecord(int stempelId)
    {
        _recordsDeleting = true;
        try
        {
            var (ok, _) = await RecordService.DeleteAsync(stempelId);
            if (ok)
            {
                _recordsSelectedIds.Remove(stempelId);
                await LoadRecords();
            }
        }
        finally
        {
            _recordsDeleting = false;
        }
    }

    private void ConfirmBulkDeleteRecords()
    {
        if (_recordsSelectedIds.Count == 0) return;
        _showBulkDeleteConfirm = true;
    }

    private void CancelBulkDeleteRecords()
    {
        _showBulkDeleteConfirm = false;
    }

    private async Task DoBulkDeleteRecords()
    {
        CancelBulkDeleteRecords();
        await BulkDeleteRecords();
    }

    private async Task BulkDeleteRecords()
    {
        if (_recordsSelectedIds.Count == 0) return;
        _recordsDeleting = true;
        try
        {
            var (deleted, errors) = await RecordService.BulkDeleteAsync(_recordsSelectedIds.ToList());
            if (errors.Count > 0)
                foreach (var err in errors) { }
            _recordsSelectedIds.Clear();
            await LoadRecords();
        }
        finally
        {
            _recordsDeleting = false;
        }
    }

    private void OnBatchFileSelected(InputFileChangeEventArgs e)
    {
        _batchFile = e.File;
        _batchResult = null;
    }

    private void OnBatchImagesSelected(InputFileChangeEventArgs e)
    {
        _batchImageFiles = e.GetMultipleFiles(200);
        _batchResult = null;
    }

    private async Task RunBatchImport()
    {
        if (_batchFile == null) return;
        _batchImporting = true;
        _batchResult = null;
        try
        {
            await using var stream = _batchFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            List<(string FileName, byte[] Content)>? uploadedImages = null;
            if (_batchImageFiles.Count > 0)
            {
                uploadedImages = new List<(string FileName, byte[] Content)>();
                foreach (var file in _batchImageFiles)
                {
                    await using var ms = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    using var buffer = new MemoryStream();
                    await ms.CopyToAsync(buffer);
                    uploadedImages.Add((file.Name, buffer.ToArray()));
                }
            }
            _batchResult = await BatchImportService.ProcessExcelAsync(stream, uploadedImages);
            _batchFile = null;
            _batchImageFiles = Array.Empty<IBrowserFile>();
        }
        catch (Exception ex)
        {
            _batchResult = new BatchImportResultDto
            {
                Imported = 0,
                Skipped = 0,
                Errors = new List<string> { "Import failed: " + ex.Message }
            };
        }
        finally
        {
            _batchImporting = false;
        }
    }

    private async Task LoadSubcategoriesList()
    {
        _subcategoriesList = (await SubcategoryService.GetAllAsync()).ToList();
    }

    private void OpenSubcategoryCreate()
    {
        _editingSubcategory = null;
        _subcategoryStempeltypeId = _recordsDropdowns.Stempeltyper.FirstOrDefault()?.StempeltypeId ?? 0;
        _subcategoryCode = "";
        _subcategoryFullTekst = "";
        _subcategoryError = null;
        _showSubcategoryModal = true;
    }

    private void OpenSubcategoryEdit(SubcategoryDto sc)
    {
        _editingSubcategory = sc;
        _subcategoryStempeltypeId = sc.StempeltypeId;
        _subcategoryCode = sc.Underkategori;
        _subcategoryFullTekst = sc.UnderkategoriFullTekst ?? "";
        _subcategoryError = null;
        _showSubcategoryModal = true;
    }

    private void CloseSubcategoryModal()
    {
        _showSubcategoryModal = false;
        _editingSubcategory = null;
    }

    private async Task SaveSubcategory()
    {
        _subcategoryError = null;
        if (_subcategoryStempeltypeId <= 0) { _subcategoryError = "Select stamp type."; return; }
        if (string.IsNullOrWhiteSpace(_subcategoryCode)) { _subcategoryError = "Code is required."; return; }
        _subcategorySaving = true;
        try
        {
            if (_editingSubcategory == null)
            {
                var (ok, _, err) = await SubcategoryService.CreateAsync(new SubcategoryCreateRequest { StempeltypeId = _subcategoryStempeltypeId, Underkategori = _subcategoryCode.Trim(), UnderkategoriFullTekst = string.IsNullOrWhiteSpace(_subcategoryFullTekst) ? null : _subcategoryFullTekst.Trim() });
                if (ok) { CloseSubcategoryModal(); await LoadSubcategoriesList(); } else _subcategoryError = err;
            }
            else
            {
                var (ok, err) = await SubcategoryService.UpdateAsync(_editingSubcategory.UnderkategoriId, new SubcategoryUpdateRequest { Underkategori = _subcategoryCode.Trim(), UnderkategoriFullTekst = string.IsNullOrWhiteSpace(_subcategoryFullTekst) ? null : _subcategoryFullTekst.Trim() });
                if (ok) { CloseSubcategoryModal(); await LoadSubcategoriesList(); } else _subcategoryError = err;
            }
        }
        finally { _subcategorySaving = false; }
    }

    private async Task DeleteSubcategory(SubcategoryDto sc)
    {
        _subcategorySaving = true;
        try
        {
            var (ok, err) = await SubcategoryService.DeleteAsync(sc.UnderkategoriId);
