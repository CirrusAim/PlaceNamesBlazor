    private async Task LoadAuditLogs()
    {
        DateTime? dateFrom = _auditDateFrom?.ToDateTime(TimeOnly.MinValue);
        DateTime? dateTo = _auditDateTo?.ToDateTime(TimeOnly.MinValue);
        _auditLoading = true;
        try
        {
            _auditTotalCount = await AuditService.GetLogsCountAsync(
                string.IsNullOrWhiteSpace(_auditActionType) ? null : _auditActionType.Trim(),
                string.IsNullOrWhiteSpace(_auditActorFilter) ? null : _auditActorFilter.Trim(),
                dateFrom,
                dateTo);
            var offset = (_auditPage - 1) * AdminPageSize;
            _auditLogs = (await AuditService.GetLogsAsync(
                string.IsNullOrWhiteSpace(_auditActionType) ? null : _auditActionType.Trim(),
                string.IsNullOrWhiteSpace(_auditActorFilter) ? null : _auditActorFilter.Trim(),
                dateFrom,
                dateTo,
                AdminPageSize,
                offset)).ToList();
        }
        finally
        {
            _auditLoading = false;
        }
    }

