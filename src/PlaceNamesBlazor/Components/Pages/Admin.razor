    private string GetAuditActionType(string? actionType)
    {
        if (string.IsNullOrEmpty(actionType)) return "";
        var v = Loc["Audit_" + actionType].Value;
        return string.IsNullOrEmpty(v) ? System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(actionType.Replace("_", " ").ToLowerInvariant()) : v;
    }

