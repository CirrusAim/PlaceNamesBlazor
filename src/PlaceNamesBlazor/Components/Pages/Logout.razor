@page "/{locale:regex(no|en)}/logout"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Logging out…</PageTitle>

<p>Redirecting…</p>

@code {
    [Parameter]
    public string Locale { get; set; } = "no";

    protected override void OnInitialized()
    {
        Navigation.NavigateTo($"/{Locale}/Account/Logout", forceLoad: true);
    }
}
