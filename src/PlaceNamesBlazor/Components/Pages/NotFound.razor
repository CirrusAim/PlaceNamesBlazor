@page "/{locale:regex(no|en)}/not-found"
@inject ICurrentLocaleService LocaleService
@inject IStringLocalizer<SharedResource> Loc

<div class="text-center py-5">
    <div class="card d-inline-block text-start">
        <div class="card-body p-4">
            <h1 class="display-4 text-muted mb-2">404</h1>
            <h2 class="page-title h4 mb-3">@Loc["NotFound_Title"]</h2>
            <p class="text-muted mb-4">@Loc["NotFound_Message"]</p>
            <a href="/@(LocaleService.GetCurrentLocale())" class="btn btn-primary">@Loc["NotFound_GoHome"]</a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Locale { get; set; } = "no";
}