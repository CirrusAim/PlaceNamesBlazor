{
  "Database": {
    "UseLocalDatabase": true,
    "Mode": "Local"
  },
  "ConnectionStrings": {
    "Local": "Host=localhost;Database=place_names_db;Username=postgres;Password=YOUR_DB_PASSWORD;Port=5432;Ssl Mode=Prefer",
    "DefaultConnection": "Host=localhost;Database=place_names_db;Username=postgres;Password=YOUR_DB_PASSWORD;Port=5432;Ssl Mode=Prefer"
  },
  "ImageStorage": {
    "Provider": "Local",
    "Local": {
      "BasePath": ""
    },
    "Cloudflare": {
      "AccountId": "YOUR_CLOUDFLARE_ACCOUNT_ID",
      "AccessKeyId": "YOUR_CLOUDFLARE_ACCESS_KEY_ID",
      "SecretAccessKey": "YOUR_CLOUDFLARE_SECRET_ACCESS_KEY",
      "BucketName": "YOUR_R2_BUCKET_NAME",
      "PublicBaseUrl": "https://YOUR_R2_PUBLIC_BASE_URL"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  }
}
