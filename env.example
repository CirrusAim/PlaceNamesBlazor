# ---------------------------------------------------------------------------
# Database: Local vs Remote (Render) – same idea as Flask .env
# ---------------------------------------------------------------------------
# Use local PostgreSQL (e.g. when running dotnet run on your machine)
# Set in appsettings.Development.json: "Database": { "UseLocalDatabase": true }
# and set ConnectionStrings:Local (or DB_* below) with your local password.

# When UseLocalDatabase = false (or Mode = Remote), the app uses DATABASE_URL (e.g. from Render).
# On Render, set DATABASE_URL in the dashboard; do not set UseLocalDatabase (defaults to remote when DATABASE_URL exists).

# Optional: override via environment variables (for local, same names as Flask)
# DB_HOST=localhost
# DB_NAME=place_names_db
# DB_USER=postgres
# DB_PASSWORD=your_local_password
# DB_PORT=5432
# DB_SSLMODE=Prefer

# Force local even if DATABASE_URL is set (like Flask FORCE_LOCAL_DB=1)
# Database__UseLocalDatabase=true

# Or use Remote explicitly (e.g. test against Render DB from your machine)
# Database__Mode=Remote
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ---------------------------------------------------------------------------
# First admin (created at startup if no admin exists)
# ---------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin123

# ---------------------------------------------------------------------------
# Image storage (optional)
# ---------------------------------------------------------------------------
# ImageStorage__Provider=Local
# ImageStorage__Provider=Cloudflare
# ImageStorage__Cloudflare__AccountId=...
# ImageStorage__Cloudflare__AccessKeyId=...
# ImageStorage__Cloudflare__SecretAccessKey=...
# ImageStorage__Cloudflare__BucketName=place-names-images
# ImageStorage__Cloudflare__PublicBaseUrl=...
